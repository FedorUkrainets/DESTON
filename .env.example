# =============================================================================
# DESTON — Environment variables (example).
# Copy this file to `.env.local` for development and `.env` for production.
# Never commit real secrets to the repository.
# =============================================================================

# ---- Application ----
NODE_ENV="development"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_NAME="DESTON"

# ---- Database (PostgreSQL) ----
